{
  "expo": {
    "name": "VAULT",
    "slug": "vault",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "vault",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0E0B08"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.getvault.app",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "VAULT uses your camera to scan financial documents and statements.",
        "NSPhotoLibraryUsageDescription": "VAULT accesses your photo library to scan financial documents and statements.",
        "NSFaceIDUsageDescription": "VAULT uses Face ID to keep your financial data secure."
      }
    },
    "android": {
      "package": "com.getvault.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#0E0B08",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "VAULT accesses your photo library to scan financial documents.",
          "cameraPermission": "VAULT uses your camera to scan financial documents."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "1bd77465-3a6e-4210-a447-faee867083cb"
      }
    },
    "owner": "omarreidy23"
  }
}
